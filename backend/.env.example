# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./vibeslol.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/vibeslol?sslmode=require

# JWT
SECRET_KEY=change-me-to-a-random-string
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Cloudflare R2 (leave blank for local file storage)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://your-r2-domain.com

# Redis (leave blank to disable caching)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# CORS (comma-separated origins, or * for dev)
# CORS_ORIGINS=["https://yourdomain.com"]

# Environment
ENVIRONMENT=development
